{
  "name": "creatoros-backend",
  "version": "1.0.0",
  "description": "CreatorOS backend for student-only digital marketplace",
  "main": "server.js",
  "type": "commonjs",
  "engines": {
    "node": ">=18.18.0"
  },
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "lint": "node --check server.js && find src -name '*.js' -print0 | xargs -0 -n1 node --check",
    "test": "jest --runInBand",
    "build": "node -e \"console.log('Build not required for pure Node.js runtime')\""
  },
  "keywords": [
    "creatoros",
    "marketplace",
    "express",
    "mongoose"
  ],
  "author": "CreatorOS",
  "license": "MIT",
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.6.1",
    "express": "^4.21.2",
    "express-rate-limit": "^7.5.1",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.22.1",
    "multer": "^2.1.1",
    "nodemailer": "^9.0.1",
    "openai": "^4.104.0",
    "pdf-lib": "^1.17.1",
    "razorpay": "^2.9.6",
    "@google/generative-ai": "^0.21.0"
  },
  "overrides": {
    "js-yaml": "^4.2.0"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "nodemon": "^3.1.10",
    "supertest": "^7.1.4"
  }
}
