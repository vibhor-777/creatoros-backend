NODE_ENV=development
PORT=4000
MONGODB_URI=mongodb://127.0.0.1:27017/creatoros
JWT_SECRET=replace_with_64_character_secret
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=replace_with_64_character_refresh_secret
JWT_REFRESH_EXPIRES_IN=30d
ALLOWED_ORIGINS=http://localhost:3000
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# Student access controls
EDU_EMAIL_DOMAINS=edu,ac.in,ac.uk,college.edu
REQUIRE_EDU_VERIFICATION=true

# Razorpay
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxx
RAZORPAY_KEY_SECRET=replace_with_razorpay_secret
RAZORPAY_WEBHOOK_SECRET=replace_with_razorpay_webhook_secret

# OpenAI
OPENAI_API_KEY=sk-replace_with_openai_key
OPENAI_MODEL=gpt-4o-mini

# GitHub
GITHUB_TOKEN=ghp_replace_with_fine_grained_token
GITHUB_OWNER=creatoros-org
GITHUB_REPO=creatoros-backend

# Shiprocket
SHIPROCKET_EMAIL=ops@creatoros.edu
SHIPROCKET_PASSWORD=replace_with_shiprocket_password
SHIPROCKET_PICKUP_PIN=110001

# Storage paths
UPLOAD_DIR=uploads
WATERMARK_OUTPUT_DIR=uploads/watermarked
DIGITAL_VAULT_DIR=uploads/vault

# SMTP
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=notify@creatoros.edu
SMTP_PASS=replace_with_smtp_password
MAIL_FROM=CreatorOS <notify@creatoros.edu>

# Optional service toggles
ENABLE_AI_SERVICES=true
ENABLE_PHYSICAL_GOODS=true
ENABLE_GITHUB_BOUNTIES=true
